# ── Core ────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_key_here

# ── Session ─────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-this-to-a-random-32-char-secret

# Set to "true" on Railway/production (HTTPS)
SESSION_HTTPS_ONLY=false

# ── Google OAuth ─────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Apple Sign In (optional) ─────────────────────────
# Requires Apple Developer account ($99/yr)
APPLE_CLIENT_ID=

# ── Database ─────────────────────────────────────────
# Leave blank → SQLite at ./data/portfolio.db
# For Railway: set to Postgres URL from Railway Postgres plugin
DATABASE_URL=
